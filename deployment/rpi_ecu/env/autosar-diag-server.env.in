# AUTOSAR Diagnostic Server daemon environment

AUTOSAR_AP_PREFIX="__AUTOSAR_AP_PREFIX__"
AUTOSAR_DIAG_SERVER_BIN="__AUTOSAR_AP_PREFIX__/bin/autosar_diag_server"

# TCP listen address and port (standard DoIP port = 13400)
AUTOSAR_DIAG_LISTEN_ADDR="0.0.0.0"
AUTOSAR_DIAG_LISTEN_PORT="13400"

# UDS P2 / P2* response timing (ms)
AUTOSAR_DIAG_P2_SERVER_MS="50"
AUTOSAR_DIAG_P2STAR_SERVER_MS="5000"

# Status file update period (ms)
AUTOSAR_DIAG_STATUS_PERIOD_MS="5000"
AUTOSAR_DIAG_STATUS_FILE="/run/autosar/diag_server.status"
