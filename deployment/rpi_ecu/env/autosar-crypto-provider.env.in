# AUTOSAR Cryptography key management provider daemon environment

AUTOSAR_AP_PREFIX="__AUTOSAR_AP_PREFIX__"
AUTOSAR_CRYPTO_PROVIDER_BIN="__AUTOSAR_AP_PREFIX__/bin/autosar_crypto_provider"

# HSM token label
AUTOSAR_CRYPTO_TOKEN="AutosarEcuHsm"

# Main loop period (ms)
AUTOSAR_CRYPTO_PERIOD_MS="5000"

# Key rotation (disabled by default; enable for production)
AUTOSAR_CRYPTO_KEY_ROTATION="false"
AUTOSAR_CRYPTO_ROTATION_INTERVAL_MS="3600000"

# Self-test
AUTOSAR_CRYPTO_SELF_TEST="true"
AUTOSAR_CRYPTO_SELF_TEST_INTERVAL_MS="60000"

AUTOSAR_CRYPTO_STATUS_FILE="/run/autosar/crypto_provider.status"
