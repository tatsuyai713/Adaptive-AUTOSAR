# AUTOSAR Platform Health Management daemon environment

AUTOSAR_AP_PREFIX="__AUTOSAR_AP_PREFIX__"
AUTOSAR_PHM_DAEMON_BIN="__AUTOSAR_AP_PREFIX__/bin/autosar_phm_daemon"

# Health evaluation period (ms)
AUTOSAR_PHM_PERIOD_MS="3000"

# Thresholds: number of failed entities for degraded / critical status
AUTOSAR_PHM_DEGRADED_THRESHOLD="2"
AUTOSAR_PHM_CRITICAL_THRESHOLD="4"

# Comma-separated list of supervised entities
AUTOSAR_PHM_ENTITIES="adaptive_autosar,autosar_can_interface_manager,autosar_watchdog_supervisor,autosar_user_app_monitor,autosar_sm_state_daemon,autosar_time_sync_daemon,autosar_persistency_guard,autosar_iam_policy_loader,autosar_ntp_time_provider,autosar_ptp_time_provider,autosar_network_manager,autosar_ucm_daemon,autosar_dlt_daemon"

AUTOSAR_PHM_STATUS_FILE="/run/autosar/phm.status"
